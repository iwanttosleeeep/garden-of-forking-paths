-    async def _process_single_chunk(self, chunk: dict, preserve_raw: bool):
-        """Extract memories from a single chunk and store them."""
-        content = chunk["content"]
-        if not content.strip():
-            return
-
-        # --- LLM extraction ---
-        try:
-            items = await self._extract_memories(content)
